# =============================================================================
# AV Site Survey Web App - Environment Configuration
# =============================================================================
# Copy this file to ".env" and fill in the values below.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Server -------------------------------------------------------------------
# Port the Express server listens on (default: 3000).
PORT=3000

# --- SMTP Email ---------------------------------------------------------------
# Host and port for the outbound SMTP server.
# Office 365:  smtp.office365.com / 587
# Gmail:       smtp.gmail.com     / 587
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# Credentials for the sender mailbox.
# For Gmail, you MUST use an App Password (not your regular password).
# Generate one at: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER=
EMAIL_PASS=

# --- Notification Recipients --------------------------------------------------
# Comma-separated list of email addresses that receive survey submission reports.
EMAIL_RECIPIENTS=
